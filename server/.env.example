# ═══════════════════════════════════════════════════════
# TENX Track Learning — Environment Configuration
# Copy this file as .env and fill in your own values
# ═══════════════════════════════════════════════════════

# ─── Server ───
PORT=5005
FRONTEND_URL=http://localhost:5173

# ─── Supabase ───
# Create a project at https://supabase.com and get these values from Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── GNews API ───
# Get a free API key at https://gnews.io
GNEWS_API_KEY=your-gnews-api-key
GNEWS_MAX_CALLS_PER_DAY=5

# ─── Groq AI API ───
# Get an API key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_CALLS_PER_DAY=10

# ─── Website Config ───
WEBSITE_NAME=TENX Track Learning
LOGO_TEXT=TENX Track Learning
