<?xml version="1.0" encoding="utf-8"?>
<!-- Countdown card: bg-secondary with subtle gradient overlay -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_secondary" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/border_default" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0F6366F1"
                android:endColor="#0AA855F7"
                android:angle="135" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
