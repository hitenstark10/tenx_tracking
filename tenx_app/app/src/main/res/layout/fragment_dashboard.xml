<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ═══ Quote Hero Card (vertical center layout like web mobile) ═══ -->
        <LinearLayout
            android:id="@+id/quoteCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_quote_hero"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <!-- Sparkle icon circle (centered above text like web mobile) -->
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_accent_gradient"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="22sp"
                    android:layout_gravity="center" />
            </FrameLayout>

            <!-- Badge row: Category + AI Generated (matching web's badges) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/quoteLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_inspiration"
                    android:textColor="@color/accent_primary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/quoteCategoryBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A78BFA"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/quoteAiBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ AI GENERATED"
                    android:textColor="#34D399"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/quoteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/loading_inspiration"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="italic"
                android:lineSpacingMultiplier="1.5"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/quoteAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ═══ Countdown Timer Card (full width, below quote, matching web mobile) ═══ -->
        <LinearLayout
            android:id="@+id/countdownCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_countdown_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳"
                    android:textSize="20sp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">

                    <!-- Days -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/cdDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAYS"
                            android:textColor="@color/text_tertiary"
                            android:textSize="8sp"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="@color/accent_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="3dp"
                        android:layout_gravity="top" />

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/cdHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HRS"
                            android:textColor="@color/text_tertiary"
                            android:textSize="8sp"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="@color/accent_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="3dp"
                        android:layout_gravity="top" />

                    <!-- Minutes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/cdMins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIN"
                            android:textColor="@color/text_tertiary"
                            android:textSize="8sp"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="@color/accent_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="3dp"
                        android:layout_gravity="top" />

                    <!-- Seconds -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/cdSecs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEC"
                            android:textColor="@color/text_tertiary"
                            android:textSize="8sp"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Bottom: label + set button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/countdownTargetText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Countdown Timer"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>

        <!-- ═══ ROW 1: Overview Stats Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_overview"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Header: Overview + Today/Overall tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊  Overview"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_stat_item"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/tabToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/today"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_active"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" />

                    <TextView
                        android:id="@+id/tabOverall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overall"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats Grid: 2x2 — each with icon square + label + value (matches web layout) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Tasks stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_info"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅"
                            android:textSize="16sp"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Tasks"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.03" />
                        <TextView
                            android:id="@+id/statTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/0"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Study stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_success"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📖"
                            android:textSize="16sp"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Study Hours"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.03" />
                        <TextView
                            android:id="@+id/statStudy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Curriculum stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_warning"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="16sp"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Curriculum"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.03" />
                        <TextView
                            android:id="@+id/statCurriculum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/0"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Progression stat (with accent tint) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_progression"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_active"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progression"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.03" />
                        <TextView
                            android:id="@+id/statProgression"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Activity Heatmap Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_heatmap"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗓️  Activity Heatmap"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <com.example.myapplication.widget.HeatmapView
                android:id="@+id/heatmapContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- ═══ Mini Cards Row: Papers 100% | Day Streak | Stopwatch ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:baselineAligned="false">

            <!-- Papers 100% -->
            <LinearLayout
                android:id="@+id/papersCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card_papers"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/papersValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAPERS 100%"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Day Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card_streak"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginHorizontal="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/streakValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAY STREAK"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Stopwatch -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card_stopwatch"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️"
                    android:textSize="18sp"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/stopwatchValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:id="@+id/swToggleBtn"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_chip_active"
                        android:text="▶"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/swSaveBtn"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_chip"
                        android:text="💾"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/swResetBtn"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_chip"
                        android:text="↺"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOPWATCH"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Today's Tasks Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✅  Today's Tasks"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dashAddTaskBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="➕"
                    android:textSize="12sp"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/todayTasksList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/noTasksText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_tasks_today"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- ═══ Today's Topics Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📘  Today's Course Topics"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/todayTopicsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/noTopicsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_topics_today"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- ═══ Performance Charts Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Chart Category Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/chartTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chartTabTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ Tasks"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:background="@drawable/bg_chip_active"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/chartTabStudy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📖 Study"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:background="@drawable/bg_chip"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/chartTabCurriculum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚 Curriculum"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:background="@drawable/bg_chip"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/chartTabPapers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📄 Research"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:background="@drawable/bg_chip"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Range Tabs -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/range7d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 Days"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:background="@drawable/bg_chip_active"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/range30d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 Days"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:background="@drawable/bg_chip"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp" />
                </LinearLayout>
            </LinearLayout>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="220dp" />
        </LinearLayout>

        <!-- ═══ Trending News Ticker ═══ -->
        <LinearLayout
            android:id="@+id/dashNewsWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📰  Trending News"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/dashNewsViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="@color/accent_primary"
                    android:textSize="11sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/dashNewsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
                
            <TextView
                android:id="@+id/noNewsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading latest news..."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"
                android:padding="16dp" />
        </LinearLayout>

        <!-- ═══ Milestones Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_milestone"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏆  Milestones"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trophy "
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/milestoneSummaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/10 Achieved"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Milestones Grid Container -->
            <GridLayout
                android:id="@+id/dashMilestoneGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true" />
        </LinearLayout>

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
