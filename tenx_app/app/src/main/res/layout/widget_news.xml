<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2B3A"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📰 Daily Tech News"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/widgetNewsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E0E0E0"
        android:textSize="13sp"
        android:text="Google drops new Gemini architecture focusing on agentic environments yielding massive benchmarks improvements... Read more"
        android:lineSpacingMultiplier="1.3" />
        
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="via TechCrunch"
        android:textColor="#9E9E9E"
        android:textSize="11sp"
        android:gravity="end"
        android:layout_marginTop="12dp"/>
</LinearLayout>
