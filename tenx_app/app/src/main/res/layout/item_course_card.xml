<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/courseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/coursePriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/courseDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_tertiary"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Counts Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/topicCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/subtopicCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <!-- Progress Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ProgressBar
            android:id="@+id/courseProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:max="100"
            android:progressDrawable="@drawable/bg_accent_gradient"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/courseProgressPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_primary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/courseDates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/editCourseBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_edit"
            android:padding="4dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Edit" />

        <ImageView
            android:id="@+id/deleteCourseBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_delete"
            android:padding="4dp"
            android:contentDescription="Delete" />
    </LinearLayout>
</LinearLayout>
