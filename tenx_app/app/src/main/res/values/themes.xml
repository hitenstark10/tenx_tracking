<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — Force Dark -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/accent_secondary</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorPrimaryContainer">@color/accent_glow</item>
        <item name="colorOnPrimaryContainer">@color/accent_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/accent_tertiary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorSurfaceVariant">@color/bg_tertiary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/danger</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status Bar & Nav Bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_muted</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/accent_glow</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <!-- ═══ Text Styles ═══ -->
    <style name="TextHeadline" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextTitle" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextSubtitle" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextBody" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextCaption" parent="">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextStatValue" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextStatLabel" parent="">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <!-- ═══ Card Styles ═══ -->
    <style name="TenxCard" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="TenxCardElevated" parent="TenxCard">
        <item name="android:background">@drawable/bg_card_elevated</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- ═══ Button Styles ═══ -->
    <style name="BtnPrimary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_btn_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="BtnGhost" parent="">
        <item name="android:background">@drawable/bg_btn_ghost</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ═══ Input Style ═══ -->
    <style name="TenxInput" parent="">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:textSize">15sp</item>
        <item name="android:padding">14dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- ═══ Badge Styles ═══ -->
    <style name="BadgeHigh" parent="">
        <item name="android:background">@drawable/bg_badge_high</item>
        <item name="android:textColor">@color/priority_high</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="BadgeMedium" parent="BadgeHigh">
        <item name="android:background">@drawable/bg_badge_medium</item>
        <item name="android:textColor">@color/priority_medium</item>
    </style>

    <style name="BadgeLow" parent="BadgeHigh">
        <item name="android:background">@drawable/bg_badge_low</item>
        <item name="android:textColor">@color/priority_low</item>
    </style>

    <style name="BadgeInfo" parent="BadgeHigh">
        <item name="android:background">@drawable/bg_badge_info</item>
        <item name="android:textColor">@color/info</item>
    </style>

    <!-- ═══ Centered Dialog (named TenxBottomSheet to preserve references) ═══ -->
    <style name="TenxBottomSheet" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/bg_card_glass</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="shapeAppearance">@style/TenxDialogShape</item>
    </style>

    <style name="TenxDialogShape" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ═══ Splash Theme ═══ -->
    <style name="Theme.TenX.Splash" parent="Theme.MyApplication">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>